{
  "name": "cl-booth-library-manager",
  "version": "0.2.0",
  "private": true,
  "description": "BOOTHのライブラリを管理するデスクトップアプリ",
  "author": "iamlinggggg",
  "license": "MIT",
  "main": "dist/main/index.js",
  "scripts": {
    "predev": "tsc -p tsconfig.main.json",
    "dev": "concurrently --kill-others -k \"vite\" \"wait-on http://localhost:5173 && electron . --no-sandbox\"",
    "kill": "pkill -9 -f sbcl; pkill -9 -f electron; pkill -9 -f vite; fuser -k 5173/tcp 57284/tcp 2>/dev/null || true",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --x64 --publish never"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.28.7",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.iamlinggggg.booth-library-manager",
    "productName": "BOOTH Library Manager",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../dist-cl/",
        "to": "cl-backend/",
        "filter": ["*.exe", "*.dll"]
      }
    ],
    "win": {
      "target": "portable"
    }
  }
}